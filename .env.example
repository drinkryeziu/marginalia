# Supabase connection — copy this file to `.env` and fill in your values.
# Find both under: Supabase Dashboard → Project Settings → API
#
# The anon key is meant to be used in the browser and is safe to expose in the
# built site; your data is protected by the row-level security rules in
# supabase/schema.sql. Never put the *service_role* key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
